# Powernode bootc-compatible OCI image.
#
# Track F bootc evolution path: this image can be used to boot a real
# system via the bootc workflow (https://containers.github.io/bootc/) —
# the entire OS is the container image, kernel and all.
#
# v0 stages: minimal Ubuntu 24.04 + kernel + dracut + powernode-agent.
# The Containerfile is parameterized by BASE_IMAGE_DIGEST so reproducible
# builds can pin the exact base layer.
#
# Reference: Golden Eclipse plan M3 — images/oci.

ARG BASE_IMAGE_DIGEST=ubuntu@sha256:placeholder-pin-via-ci-input
FROM ${BASE_IMAGE_DIGEST}

ARG TARGETARCH
LABEL org.opencontainers.image.source="https://git.ipnode.org/powernode/powernode-platform" \
      org.opencontainers.image.description="Powernode bootc-compatible OS image" \
      org.opencontainers.image.licenses="proprietary" \
      org.powernode.boot.role="installer"

# Pinned APT snapshot — must match the M1 reproducibility gate. CI sets
# this via build-arg.
ARG APT_SNAPSHOT=20260430T000000Z
RUN echo "deb [trusted=yes] https://snapshot.debian.org/archive/debian/${APT_SNAPSHOT}/ stable main" \
      > /etc/apt/sources.list.d/snapshot.list

RUN apt-get update && apt-get install -y --no-install-recommends \
      linux-image-generic \
      dracut-core \
      systemd \
      systemd-networkd \
      iproute2 \
      composefs-tools \
      ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Stage the agent binary (built by extensions/system/agent CI for matching arch).
COPY powernode-agent-${TARGETARCH} /sbin/powernode-agent
RUN chmod +x /sbin/powernode-agent

# Powernode dracut module
COPY modules.d/90powernode/ /usr/lib/dracut/modules.d/90powernode/
COPY dracut.conf.d/ /etc/dracut.conf.d/

# Rebuild initramfs so the powernode module is included
RUN kver="$(ls /lib/modules | head -n1)" && \
    dracut --force --kver "$kver" --modules powernode

# Set the entrypoint to systemd — bootc expects PID 1 to be init.
CMD ["/sbin/init"]
